% neurips_2026.sty - Style file for NeurIPS 2026 (Datasets & Benchmarks Track)
% Based on the standard NeurIPS format (consistent since 2019+)
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2026}[2026/01/15 NeurIPS 2026 submission package]

\newif\if@preprint\@preprintfalse
\newif\if@final\@finalfalse
\newif\if@nonatbib\@nonatbibfalse
\DeclareOption{preprint}{\@preprinttrue}
\DeclareOption{final}{\@finaltrue}
\DeclareOption{nonatbib}{\@nonatbibtrue}
\ProcessOptions\relax

% Fonts and encoding
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{times}

% Page layout: NeurIPS standard
\RequirePackage[verbose=true,letterpaper]{geometry}
\AtBeginDocument{
  \newgeometry{
    textheight=9in,
    textwidth=5.5in,
    top=1in,
    headheight=12pt,
    headsep=25pt,
    footskip=30pt
  }
}

% Line numbers for review
\if@final\else
  \if@preprint\else
    \RequirePackage{lineno}
    \linenumbers
  \fi
\fi

% Natbib
\if@nonatbib\else
  \RequirePackage[numbers,sort&compress]{natbib}
\fi

% Standard packages
\RequirePackage{hyperref}
\RequirePackage{url}
\RequirePackage{booktabs}
\RequirePackage{amsfonts}
\RequirePackage{nicefrac}
\RequirePackage{microtype}
\RequirePackage{xcolor}

% Colors
\definecolor{mydarkblue}{rgb}{0,0.08,0.45}
\hypersetup{
  colorlinks=true,
  linkcolor=mydarkblue,
  citecolor=mydarkblue,
  urlcolor=mydarkblue,
}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}

% Abstract
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.5ex}%
  \begin{quote}%
}{%
  \end{quote}%
}

% Title
\def\@maketitle{%
  \vbox to \titlebox{%
    \vskip 0.4in%
    \begin{center}%
      {\LARGE\bfseries \@title \par}%
      \vskip 0.3in%
      \if@final%
        {\large\lineskip .5em%
         \begin{tabular}[t]{c}%
           \@author%
         \end{tabular}\par}%
      \else%
        \if@preprint%
          {\large\lineskip .5em%
           \begin{tabular}[t]{c}%
             \@author%
           \end{tabular}\par}%
        \else%
          {\large Anonymous Author(s)\par}%
          {\normalsize Submit to NeurIPS 2026. Do not distribute.\par}%
        \fi%
      \fi%
      \vskip 0.3in%
    \end{center}%
  }%
}
\newlength\titlebox
\setlength\titlebox{2.5in}

% Footnote
\renewcommand\footnoterule{%
  \kern-3\p@%
  \hrule width 2in%
  \kern 2.6\p@%
}

% Headers
\RequirePackage{fancyhdr}
\fancyhf{}
\if@final
  \fancyhead[C]{}
\else
  \if@preprint
    \fancyhead[C]{Preprint. Under review.}
  \else
    \fancyhead[C]{Submitted to NeurIPS 2026 Datasets \& Benchmarks Track}
  \fi
\fi
\fancyfoot[C]{\thepage}
\pagestyle{fancy}
\renewcommand{\headrulewidth}{0pt}

\endinput